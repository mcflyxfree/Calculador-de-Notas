<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Promedio</title>
</head>
<body>

    <h2>Calculadora de Promedio</h2>

    <form id="calcForm">
        <label>Nota 1: <input type="number" step="any" id="n1" required></label><br><br>
        <label>Nota 2: <input type="number" step="any" id="n2" required></label><br><br>
        <label>Nota 3: <input type="number" step="any" id="n3" required></label><br><br>
        
        <button type="button" onclick="calcular()">Calcular</button>
    </form>

    <h3>Promedio: <span id="resultado">0</span></h3>

    <script>
        function calcular() {
            let n1 = parseFloat(document.getElementById('n1').value) || 0;
            let n2 = parseFloat(document.getElementById('n2').value) || 0;
            let n3 = parseFloat(document.getElementById('n3').value) || 0;

            let promedio = (n1 + n2 + n3) / 3;
            document.getElementById('resultado').textContent = promedio.toFixed(2);
        }
    </script>

</body>
</html>